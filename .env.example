NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# AI Ассистент — ключ Anthropic API (console.anthropic.com → Settings → API Keys)
# Никогда не коммить реальный ключ в git — задаётся только в Vercel Environment Variables.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Опционально: переопределить модель (по умолчанию claude-sonnet-4-5-20250929)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
